<?xml version="1.0" encoding="utf-8"?>
<configuration>
  
  <appSettings>
    <!-- Configuración de la aplicación -->
    <add key="NombreAplicacion" value="Mini-Sistema de Facturación" />
    <add key="Version" value="1.0.0" />
    <add key="PorcentajeImpuestoDefecto" value="15" />
    <add key="StockMinimoDefecto" value="5" />
    <add key="ConnectionTimeout" value="30" />
    <add key="MaxReintentosConexion" value="3" />
    <add key="EnableLogging" value="true" />
    <add key="LogLevel" value="Info" />
    
    <!-- Datos de Empresa -->
    <add key="EmpresaNombre" value="Mi Empresa S.A." />
    <add key="EmpresaDireccion" value="Calle Principal #123, Ciudad" />
    <add key="EmpresaTelefono" value="+1 809-555-1234" />
    <add key="EmpresaEmail" value="info@miempresa.com" />
    <add key="EmpresaRNC" value="123456789" />
    
    <!-- Configuración NCF -->
    <add key="NCFInicio" value="01010000001" />
    <add key="NCFActual" value="01010000001" />
    <add key="NCFConsumidorFinal" value="B0100000001" />
    
    <!-- Rutas -->
    <add key="RutaPdfTickets" value="./TicketsPDF/" />
    
    <!-- Configuración Email -->
    <add key="SmtpServer" value="smtp.gmail.com" />
    <add key="SmtpPort" value="587" />
    <add key="SmtpUser" value="email@empresa.com" />
    <add key="SmtpPassword" value="password" />
    <add key="SmtpEnableSsl" value="true" />
  </appSettings>
  
  <connectionStrings>
    <!-- Cadena de conexión a SQL Server Express -->
    <add name="MiniSistemaFacturacionDB" connectionString="Server=localhost\SQLEXPRESS;Database=MiniSistemaFacturacion;Integrated Security=True;Connect Timeout=30;MultipleActiveResultSets=True;Application Name=MiniSistemaFacturacion;" providerName="System.Data.SqlClient" />
         
    <!-- Cadena de conexión alternativa (descomentar si es necesario) -->
    <!--
    <add name="MiniSistemaFacturacionDB" 
         connectionString="Server=.\SQLEXPRESS;Database=MiniSistemaFacturacion;User Id=sa;Password=tu_password;Connect Timeout=30;MultipleActiveResultSets=True;Application Name=MiniSistemaFacturacion;" 
         providerName="System.Data.SqlClient" />
    -->
  </connectionStrings>
  
  <system.data>
    <DbProviderFactories>
      <remove invariant="System.Data.SqlClient" />
      <add name="SqlClient Data Provider" invariant="System.Data.SqlClient" description=".Net Framework Data Provider for SqlServer" type="System.Data.SqlClient.SqlClientFactory, System.Data, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" />
    </DbProviderFactories>
  </system.data>
  
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  
  <runtime>
    <!-- Configuración para mejorar el rendimiento -->
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="System.Data" publicKeyToken="b77a5c561934e089" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.0.0.0" newVersion="4.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Numerics.Vectors" publicKeyToken="b03f5f7f11d50a3a" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.1.6.0" newVersion="4.1.6.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>
